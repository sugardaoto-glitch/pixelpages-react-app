DATABASE_URL="mysql://user:password@localhost:3306/pixelpages"
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# ----------------------------------------------------------------------------
# Copywriting Studio (Next.js route: /copywriting)
# ----------------------------------------------------------------------------
# Which provider to use by default. Either "openai" (any OpenAI-compatible
# /v1/chat/completions endpoint) or "gemini" (Google Generative AI).
COPYWRITING_PROVIDER="openai"

# OpenAI-compatible (works with OpenAI, OpenRouter, Groq, Ollama, etc.)
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_MODEL="gpt-4o-mini"

# Google Gemini
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-1.5-flash"
# GEMINI_BASE_URL="https://generativelanguage.googleapis.com/v1beta"
